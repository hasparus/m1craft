{
  "target_strict_score": 85,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [
    "node_modules",
    "mc-arm64",
    "bun.lock",
    ".git",
    ".desloppify",
    ".claude",
    ".cursor"
  ],
  "ignore": [
    "smells::src/lib/auth.ts::async_no_await",
    "smells::src/lib/auth.ts::console_error_no_throw",
    "smells::src/lib/auth.ts::hardcoded_url",
    "smells::src/lib/auth.ts::high_cyclomatic_complexity",
    "smells::src/lib/launch.ts::async_no_await",
    "smells::src/lib/launch.ts::console_error_no_throw",
    "smells::src/lib/launch-tui.ts::async_no_await",
    "smells::src/lib/resolve.ts::async_no_await",
    "smells::src/lib/config-tui.ts::high_cyclomatic_complexity",
    "smells::src/lib/config-tui.ts::nested_closure"
  ],
  "ignore_metadata": {},
  "zone_overrides": {},
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "issue_noise_budget": 10,
  "issue_noise_global_budget": 0,
  "execution_log_max_entries": 10000,
  "needs_rescan": false,
  "languages": {},
  "commit_tracking_enabled": true,
  "commit_pr": 0,
  "commit_default_branch": "",
  "commit_message_template": "desloppify: {status} {count} issue(s) \u2014 {summary}",
  "trust_plugins": false,
  "transition_messages": {},
  "hermes_enabled": false,
  "hermes_models": {
    "execute": "openrouter:x-ai/grok-4.20-beta",
    "review": "openrouter:google/gemini-3.1-pro-preview"
  }
}
